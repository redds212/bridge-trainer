# Supabase — skopiuj do .env.local i uzupełnij wartościami z
# Supabase → Project Settings → API. Oba klucze są publiczne (anon)
# i trafiają do builda front-endu; dane chroni RLS, nie tajność tych kluczy.
# NIGDY nie wpisuj tu service_role key.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
